{
  "datasets": [
    {
      "name": "689a4b2f",
      "displayName": "kpi_overview",
      "queryLines": [
        "SELECT\r\n",
        "    (SELECT COUNT(*)                FROM workspace.movielens.silver_ratings) AS total_ratings,\r\n",
        "    (SELECT COUNT(DISTINCT movieId) FROM workspace.movielens.silver_ratings) AS distinct_movies_rated,\r\n",
        "    (SELECT COUNT(DISTINCT userId)  FROM workspace.movielens.silver_ratings) AS distinct_users,\r\n",
        "    (SELECT ROUND(AVG(rating), 3)   FROM workspace.movielens.silver_ratings) AS overall_avg_rating;"
      ]
    },
    {
      "name": "16cf1601",
      "displayName": "genre_avg_rating_trend",
      "queryLines": [
        "SELECT\r\n",
        "    event_month,\r\n",
        "    genre,\r\n",
        "    avg_rating,\r\n",
        "    rating_count\r\n",
        "FROM workspace.movielens.gold_genre_trends\r\n",
        "WHERE rating_count >= 20\r\n",
        "ORDER BY event_month, genre;"
      ]
    },
    {
      "name": "10427ef7",
      "displayName": "rating_count_by_genre",
      "queryLines": [
        "SELECT\r\n",
        "    genre,\r\n",
        "    SUM(rating_count) AS total_ratings,\r\n",
        "    ROUND(SUM(rating_count * avg_rating) / SUM(rating_count), 3) AS weighted_avg_rating\r\n",
        "FROM workspace.movielens.gold_genre_trends\r\n",
        "GROUP BY genre\r\n",
        "ORDER BY total_ratings DESC;"
      ]
    },
    {
      "name": "6b7a5296",
      "displayName": "top_trending_movies",
      "queryLines": [
        "SELECT\r\n",
        "    event_month,\r\n",
        "    rank,\r\n",
        "    title,\r\n",
        "    rating_count,\r\n",
        "    avg_rating\r\n",
        "FROM workspace.movielens.gold_trending_movies\r\n",
        "WHERE event_month = (SELECT MAX(event_month) FROM workspace.movielens.gold_trending_movies)\r\n",
        "ORDER BY rank;"
      ]
    },
    {
      "name": "20a0b735",
      "displayName": "monthly_ratings_volume",
      "queryLines": [
        "SELECT\r\n",
        "    event_month,\r\n",
        "    COUNT(*) AS ratings_in_month\r\n",
        "FROM workspace.movielens.silver_ratings\r\n",
        "GROUP BY event_month\r\n",
        "ORDER BY event_month;"
      ]
    }
  ],
